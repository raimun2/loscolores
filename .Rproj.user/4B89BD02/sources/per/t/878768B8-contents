torgb <- function(x, from){
  if(from %in% los_colores_spaces){
    if(from == "ycbcr") {
      return(ycbcr2rgb(x))
    }
    if(from == "yiq"){
      return(yiq2rgb(x))
    }
    if(from == "yuv"){
      return(yuv2rgb(x))
    }
    if(from == "ryb"){
      return(ryb2rgb(x))
    }
    if(from == "hwb"){
      return(hwb2rgb(x))
    }
  } else {
    message("unsupported format")
  }
}

