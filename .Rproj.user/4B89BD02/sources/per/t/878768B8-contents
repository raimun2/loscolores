rgb2ycbcr_M <- matrix(c(0.299 , 0.587 , 0.114 ,
                        -0.169 , -0.331 , 0.5,
                        0.5, - 0.419 ,- 0.081), ncol = 3)
ycbcr2rgb_M <- solve(rgb2ycbcr_M)
rgb2ycbcr_K <- matrix(c(0, 128, 128))

rgb2yuv_M <- matrix(c( 0.299 , 0.587 , 0.114 ,
                       -0.147 , - 0.289 , 0.436 ,
                       0.615 , - 0.515 ,- 0.1), ncol = 3)
yuv2rgb_M <- solve(rgb2yuv_M)

rgb2yiq_M <- matrix(c( 0.299 , 0.587 , 0.114 ,
                       0.596,-0.275 ,-0.321 ,
                       0.212 ,-0.523 , 0.311), ncol = 3)
yiq2rgb_M <- solve(rgb2yiq_M)


rgb2ycbcr <- function(x) {
  dotp <- x %*% rgb2ycbcr_M

  y <-  rgb2ycbcr_K[1] + dotp[,1]
  cb <-  rgb2ycbcr_K[2] + dotp[,2]
  cr <-  rgb2ycbcr_K[3] +  dotp[,3]

  return(cbind(y, cb, cr))
}

ycbcr2rgb <- function(x) {
  y  <- x[,1] - rgb2ycbcr_K[1]
  cb <- x[,2] - rgb2ycbcr_K[2]
  cr <- x[,3] - rgb2ycbcr_K[3]

  dotp <- cbind(y,cb,cr) %*% ycbcr2rgb_M

  r <- dotp[,1]
  g <- dotp[,2]
  b <- dotp[,3]

  return(cbind(r, g, b))
}

rgb2yuv <- function(x) {
  dotp <- (x/255) %*% rgb2yuv_M

  y <-  dotp[,1]
  u <-  dotp[,2]
  v <-  dotp[,3]

  return(cbind(y, u, v))
}

yuv2rgb <- function(x) {

  dotp <- (x %*% yuv2rgb_M)*255

  r <- dotp[,1]
  g <- dotp[,2]
  b <- dotp[,3]

  return(cbind(r, g, b))
}

rgb2yiq <- function(x) {
  dotp <- (x/255) %*% rgb2yiq_M

  y <-  dotp[,1]
  i <-  dotp[,2]
  q <-  dotp[,3]

  return(cbind(y, i, q))
}

yiq2rgb <- function(x) {

  dotp <- (x %*% yiq2rgb_M)*255

  r <- dotp[,1]
  g <- dotp[,2]
  b <- dotp[,3]

  return(cbind(r, g, b))
}

rgb2ryb <- function(x){
  if(max(x)>1) x <- x/255

  r <- x[,1]
  g <- x[,2]
  b <- x[,3]

  whites <- apply(x,1,min)
  blacks <- apply(1-x,1,min)

  r <- r - whites
  g <- g - whites
  b <- b - whites

  ymin <- apply(cbind(r,g),1,min)

  r2 <- r - ymin
  y2 <- 0.5 * (g + ymin)
  b2 <- 0.5 * (b + g - ymin)

  denom <- apply(cbind(r,g,b),1,max)
  denom[denom==0] <- 1

  n <- apply(cbind(r2,y2,b2),1,max) / denom
  n[n==0] <- 1

  r2 <- r2 / n
  y2 <- y2 / n
  b2 <- b2 / n

  r <- r2 + blacks
  y <- y2 + blacks
  b <- b2 + blacks

  return(cbind(r,y,b)*255)
}

ryb2rgb <- function(x){
  x <- x/255

  r <- x[,1]
  y <- x[,2]
  b <- x[,3]

  whites <- apply(x,1,min)
  blacks <- apply(1-x,1,min)

  r <- r - blacks
  y <- y - blacks
  b <- b - blacks

  gmin <- apply(cbind(y,b),1,min)

  r2 <- r + y - gmin
  g2 <- y + gmin
  b2 <-  2 * (b - gmin)

  denom <- apply(cbind(r,y,b),1,max)
  denom[denom==0] <- 1

  n <- apply(cbind(r2,g2,b2),1,max) / denom
  n[n==0] <- 1

  r2 <- r2 / n
  g2 <- g2 / n
  b2 <- b2 / n

  r <- r2 + whites
  g <- g2 + whites
  b <- b2 + whites

  return(cbind(r,g,b)*255)
}

rgb2hwb <- function(x){
  aux <- farver::convert_colour(x, from = "rgb", to = "hsv")
  h <- aux[,1]
  w <- (1-aux[,2])*aux[,3]
  b <- 1 - aux[,3]
  return(cbind(h,w,b))
}

hwb2rgb <- function(x){
  h <- x[,1]
  s <- 1 - x[,2]/(1-x[,3])
  v <- 1 - x[,3]

  aux <- farver::convert_colour(cbind(h,s,v), from = "hsv", to = "rgb")
  return(aux)

}

color_convert <- function(x, from = NULL, to){
  if(is.null(from)){
    from <- "rgb"
  }
  if(from != to){
    if(from %in% all_spaces &
       to %in% all_spaces){
      if(is.character(x)){
        x <- farver::decode_colour(x)
      }
      if(from %in% farver_spaces & to %in% farver_spaces){
        ### cuando es un solo color cmy deja la cagada con las escalas
        return(farver::convert_colour(x, from=from , to=to))
      }
      if(from %in% farver_spaces & !(to %in% farver_spaces)){
        aux <- farver::convert_colour(x, from=from , to="rgb")
        out <- fromrgb(aux, to = to)
        return(out)
      }
      if(!(from %in% farver_spaces) & to %in% farver_spaces){
        aux <- torgb(x, from = from)
        out <- farver::convert_colour(aux, from="rgb", to=to)
        return(out)
      }
      if(!(from %in% farver_spaces) & !(to %in% farver_spaces)){
        aux <- torgb(x, from = from)
        out <- fromrgb(aux, to = to)
      }
    } else {
      message("unsupported format")
    }
  } else return(x)

}

