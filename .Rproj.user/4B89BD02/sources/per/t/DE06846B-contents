test_hex <- all_colors() %>% col2rgb() %>% t()

  #matrix(c(255,0,0,0,255,0,0,0,255), ncol=3)


# base R     "XYZ", "sRGB", "Apple RGB", "CIE RGB"


# sRGB
base_srgb_xyz <- convertColor(test_hex/255, from = "sRGB", to="XYZ")*100
baser_srgb_yxy <- farver::convert_colour(base_srgb_xyz, from="xyz", to="lab")

space_sRGB_XYZ <- as(colorspace::sRGB(test_hex/255), "XYZ")@coords
