science_RGB_XYZ <- colorscience::RGB2XYZ(test_hex/255)*100
science_RGB_yxy <- farver::convert_colour(science_RGB_XYZ, from="xyz", to="lab")

farver_rgb_xyz <- farver::convert_colour(test_hex, from="rgb", to="xyz")
farver_rgb_yxy <- farver::convert_colour(farver_rgb_xyz, from="xyz", to="lab")


## OTHER RGBs

