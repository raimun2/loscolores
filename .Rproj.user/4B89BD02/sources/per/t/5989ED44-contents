# spectral raster images
raster_brick_colors <- function(raster_sat, dataframe = FALSE, unique = FALSE, channels = NULL){
  if(length(names(raster_sat))>3)  {
    if(is.null(channels)) channels <- c(4,3,2)
    raster_sat <- subset(raster_sat, channels)
  }
  red <- as.matrix(subset(raster_sat, 1))
  green <- as.matrix(subset(raster_sat, 2))
  blue <- as.matrix(subset(raster_sat, 3))

  df_colors <- data.frame(
    x = rep(1:dim(red)[2], each = dim(red)[1]),
    y = rep(dim(red)[1]:1, dim(red)[2]),
    R = as.vector(red)/max(red, green, blue, na.rm = TRUE),
    G = as.vector(green)/max(red, green, blue, na.rm = TRUE),
    B = as.vector(blue)/max(red, green, blue, na.rm = TRUE))

  df_colors <- df_colors[!is.na(df_colors$R),]


  df_colors$hex = rgb(df_colors$R,df_colors$G,
                      df_colors$B,
                      maxColorValue = 1)

  if(dataframe){
    return(df_colors)
  }else{
    colorvector <- as.vector(df_colors$hex)
    if(unique){
      colorvector <- unique(colorvector)
    }
    return(colorvector)
  }
}

