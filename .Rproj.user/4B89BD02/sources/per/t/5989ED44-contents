# all possible RGB combinations
all_colors <- function(websafe = TRUE){
  if(!websafe) {
    hex <- c(0:9, LETTERS[1:6])
    pal <- expand.grid("#", hex, hex, hex, hex, hex, hex)
  } else {
    hex <- c("00", "33", "66", "99", "CC", "FF")
    pal <- expand.grid("#", hex, hex, hex)
  }
  return(pal %>% purrr::reduce(paste0))
}


# images diferent formats
read_image <- function(path){
  imagen <- magick::image_read(path)
  imagen <- as.numeric(magick::image_data(imagen, channels = "rgba"))
  return(imagen)
}

image_colors <- function(imagen, dataframe = FALSE, unique = FALSE){
  if(is.character(imagen)){
    imagen <- read_image(imagen)
  }
  if(!is.numeric(imagen)) {
    imagen <- as.numeric(magick::image_data(imagen, channels = "rgba"))
  }
  if(dataframe){
    df_colors <- data.frame(
      x = rep(1:dim(imagen)[2], each = dim(imagen)[1]),
      y = rep(dim(imagen)[1]:1, dim(imagen)[2]),
      R = as.vector(imagen[,,1]),
      G = as.vector(imagen[,,2]),
      B = as.vector(imagen[,,3]),
      alpha = as.vector(imagen[,,4]))

    df_colors$hex = rgb(df_colors$R,df_colors$G,
                        df_colors$B,df_colors$alpha,
                        maxColorValue = 1)

    return(df_colors)
  }else{
    colorvector <- rgb(imagen[,,1], imagen[,,2], imagen[,,3], imagen[,,4], maxColorValue = 1)
    if(unique){
      colorvector <- unique(colorvector)
    }
    return(colorvector)
  }
}

# rasters
## ggmap object
map_colors <- function(map, dataframe = FALSE, unique = FALSE){
  if(dataframe){
    map_mat <- apply(map, c(1, 2), function(x) as.numeric(col2rgb(x)))

    df_colors <- data.frame(
      x = rep(1:dim(map)[2], each = dim(map)[1]),
      y = rep(dim(map)[1]:1, dim(map)[2]),
      R = as.vector(map_mat[1,,])/255,
      G = as.vector(map_mat[2,,])/255,
      B = as.vector(map_mat[3,,])/255)

    df_colors$hex = rgb(df_colors$R,df_colors$G,
                        df_colors$B,
                        maxColorValue = 1)

    return(df_colors)
  }else{
    map_col <- apply(map, 1, function(x) x)
    colorvector <- as.vector(map_col)
    if(unique){
      colorvector <- unique(colorvector)
    }
    return(colorvector)
  }
}

