# gamma (or transfer curve)
gamma <- function(linear_channel, gamma = 2.4){
  ifelse(linear_channel <= 0.0031308, linear_channel * 12.92 ,  1.055*linear_channel^(1/gamma) - 0.055)
}

degamma <- function(gamma_channel, gamma = 2.4){
  ifelse ( gamma_channel <= 0.04045,gamma_channel / 12.92 , (( gamma_channel + 0.055)/1.055)^gamma)
}
