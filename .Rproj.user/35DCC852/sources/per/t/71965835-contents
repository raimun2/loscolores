rgb2ryb <- function(x){
  if(max(x)>1) x <- x/255

  r <- x[,1]
  g <- x[,2]
  b <- x[,3]

  whites <- apply(x,1,min)
  blacks <- apply(1-x,1,min)

  r <- r - whites
  g <- g - whites
  b <- b - whites

  ymin <- apply(cbind(r,g),1,min)

  r2 <- r - ymin
  y2 <- 0.5 * (g + ymin)
  b2 <- 0.5 * (b + g - ymin)

  denom <- apply(cbind(r,g,b),1,max)
  denom[denom==0] <- 1

  n <- apply(cbind(r2,y2,b2),1,max) / denom
  n[n==0] <- 1

  r2 <- r2 / n
  y2 <- y2 / n
  b2 <- b2 / n

  r <- r2 + blacks
  y <- y2 + blacks
  b <- b2 + blacks

  return(cbind(r,y,b)*255)
}

ryb2rgb <- function(x){
  x <- x/255

  r <- x[,1]
  y <- x[,2]
  b <- x[,3]

  whites <- apply(x,1,min)
  blacks <- apply(1-x,1,min)

  r <- r - blacks
  y <- y - blacks
  b <- b - blacks

  gmin <- apply(cbind(y,b),1,min)

  r2 <- r + y - gmin
  g2 <- y + gmin
  b2 <-  2 * (b - gmin)

  denom <- apply(cbind(r,y,b),1,max)
  denom[denom==0] <- 1

  n <- apply(cbind(r2,g2,b2),1,max) / denom
  n[n==0] <- 1

  r2 <- r2 / n
  g2 <- g2 / n
  b2 <- b2 / n

  r <- r2 + whites
  g <- g2 + whites
  b <- b2 + whites

  return(cbind(r,g,b)*255)
}

rgb2hwb <- function(x){
  aux <- farver::convert_colour(x, from = "rgb", to = "hsv")
  h <- aux[,1]
  w <- (1-aux[,2])*aux[,3]
  b <- 1 - aux[,3]
  return(cbind(h,w,b))
}

hwb2rgb <- function(x){
  h <- x[,1]
  s <- 1 - x[,2]/(1-x[,3])
  v <- 1 - x[,3]

  aux <- farver::convert_colour(cbind(h,s,v), from = "hsv", to = "rgb")
  return(aux)

}



