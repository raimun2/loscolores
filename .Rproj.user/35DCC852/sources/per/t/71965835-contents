color_convert <- function(x, from = "hex", to = "srgb"){
  from = tolower(from)
  to = tolower(to)
  if(from %in% c("hex",all_spaces) & to %in% all_spaces){
    pcs <- "xyz"
    if(from == "hex"){
      x <- farver::decode_colour(x)/255
      x <- degamma(x)
      from <- "rgb"
    }
    if(from != to){
      if(from != pcs){
        x <- to_pcs(x, from = from)
      }
      if(to != pcs){
        x <- from_pcs(x, to = to)
      }
    }
    return(x)
  } else {
    message("unsupported format")
  }
}

