to_pcs <- function(x, from){
  pcs <- "xyz"
  if(from %in% farver_spaces){
    return(farver::convert_colour(x, from = from, to = pcs))
  }
  if(from %in% colorscience_spaces){
    return(apply(x, 2, FUN = colorscience_from_methods[[ which(from == colorscience_spaces) ]]))
  }
  if(from %in% colorscience2_spaces){
    auxpcs <- apply(x, 2, FUN = colorscience2_from_methods[[ which(from == colorscience2_spaces) ]])
    return(colorscience::RGB2XYZ(auxpcs))
  }
  if(from == "srgb"){
    return(as(colorspace::sRGB(x), "XYZ")@coords)
  }
  if(from == "rgb"){
    return(as(colorspace::RGB(x), "XYZ")@coords)
  }
  if(from %in% loscolores_spaces){
    return(apply(x, 2, FUN = loscolores_from_methods[[ which(from == colorspace_spaces) ]]))
  }
}


