rgb2ycbcr <- function(x) {
  dotp <- x %*% rgb2ycbcr_M

  y <-  rgb2ycbcr_K[1] + dotp[,1]
  cb <-  rgb2ycbcr_K[2] + dotp[,2]
  cr <-  rgb2ycbcr_K[3] +  dotp[,3]

  return(cbind(y, cb, cr))
}

ycbcr2rgb <- function(x) {
  y  <- x[,1] - rgb2ycbcr_K[1]
  cb <- x[,2] - rgb2ycbcr_K[2]
  cr <- x[,3] - rgb2ycbcr_K[3]

  dotp <- cbind(y,cb,cr) %*% ycbcr2rgb_M

  r <- dotp[,1]
  g <- dotp[,2]
  b <- dotp[,3]

  return(cbind(r, g, b))
}

